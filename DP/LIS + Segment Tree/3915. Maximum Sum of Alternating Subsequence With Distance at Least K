        dp[0][1] = arr[0];//up-ward 
        // a0[arr[0]] = arr[0];
        // a1[arr[0]] = arr[0]; 

    
        answer = max(answer,dp[0][0]); 
        answer = max(answer,dp[0][1]); 
        for(ll i=1;i<=n-1;i++){
            if((i-k)>=0){
                //a0,a1 updates for values in range [0...i-k]
                a0[arr[i-k]] = max(a0[arr[i-k]],dp[i-k][0]);
                seg0.update(1,0,n1+5,arr[i-k],a0[arr[i-k]]);
                a1[arr[i-k]] = max(a1[arr[i-k]],dp[i-k][1]);
                seg1.update(1,0,n1+5,arr[i-k],a1[arr[i-k]]);                
            }

            dp[i][0] = arr[i]; 
            dp[i][1] = arr[i];
            //dp[i][0] = arr[i] + max(a1[g],a1[g-1],....,a1[1]);
            //where g = arr[i] - 1; 
            ll g = arr[i] - 1 ; 
            // for(ll u=g;u>=1;u--){
            //     dp[i][0] = max(dp[i][0],arr[i] + a1[u]);
            // }
            if(1<=g){
                dp[i][0] = arr[i] + seg1.query(1,0,n1+5,1,g);
            }

            g = arr[i] + 1 ; 
            // for(ll u=g;u<=n1;u++){
            //     dp[i][1] = max(dp[i][1],arr[i] + a0[u]);
            // }
            if(g<=n1){
                dp[i][1] = arr[i] + seg0.query(1,0,n1+5,g,n1);                
            }

            // for(ll j=0;j<=i-1;j++){
            //     if(arr[i]>arr[j] && (i-j)>=k){
            //         dp[i][0] = max(dp[i][0],arr[i]+dp[j][1]);
            //     }
            //     if(arr[i]<arr[j] && (i-j)>=k){
            //         dp[i][1] = max(dp[i][1],arr[i]+dp[j][0]);
            //     }
            // }
            

            //cout<<dp[i][0]<<" "<<dp[i][1]<<"\n"; 
            answer = max(answer,dp[i][0]); 
            answer = max(answer,dp[i][1]); 
        }    

            return answer;
    }
};
