    int minimumDistance(string word) {
        //Memorization
        // int n = word.size();
        // vector<vector<vector<int>>> dp(n+1, vector<vector<int>>(27, vector<int>(27, -1))); //26 -> means the finger is not been assigned to any char
        
        // return solve(0, 26, 26, word, dp);

        //Tabulation
        // int n = word.size();
        // vector<vector<vector<int>>> dp(n+1, vector<vector<int>>(27, vector<int>(27, 0)));

        // for(int indx = n-1; indx >= 0; indx--) {

        //     for(int finger1 = 0; finger1 <= 26; finger1++) {

        //         for(int finger2 = 0; finger2 <= 26; finger2++) {
                    
        //             int currChar = word[indx] - 'A';

        //             int move1 = dist(finger1, currChar) + dp[indx+1][currChar][finger2];
        //             int move2 = dist(finger2, currChar) + dp[indx+1][finger1][currChar];

        //             dp[indx][finger1][finger2] = min(move1, move2);
        //         }
        //     }
        // }

        // return dp[0][26][26];

        //Space optimisation
        int n = word.size();
        vector<int> dp(27, 0); 
        //Represents minimum total abs distance with other finger at j
        // The prev indx finger contributes to the total and sits at the prev indx only we are interchanging not tracking the fingers as we used to do in the above example 
        // Here we are doing the best operations i.e min total abs dist from prevIndx finger and other free finger

        for (int indx = 1; indx < n; indx++) {
            vector<int> next(27, 1e9);

            int prev = word[indx - 1] - 'A';
            int curr = word[indx] - 'A';

            for (int j = 0; j <= 26; j++) {
                // 1️⃣ move same finger (prev → curr)
                next[j] = min(next[j], dp[j] + dist(prev, curr));

                // 2️⃣ move free finger (j → curr)
                next[prev] = min(next[prev], dp[j] + dist(j, curr));
            }

            dp = next;
        }

        return *min_element(dp.begin(), dp.end());
    }
};
