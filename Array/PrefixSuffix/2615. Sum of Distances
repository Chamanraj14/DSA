/*
ISSUE WITH CURRENT APPROACH:

We used:
    abs(total_sum_of_indices - count * i)

This assumes:
    sum(|i - j|) == |sum(j) - count * i|

This is MATHEMATICALLY INCORRECT.

Reason:
Absolute value is NOT distributive over summation:
    |a| + |b| != |a + b|   (in general)

In this problem:
Each term |i - j| behaves differently based on position:

    if j < i  → contributes (i - j)
    if j > i  → contributes (j - i)

So actual formula is:
    sum(|i - j|) =
        sum_{j < i} (i - j) + sum_{j > i} (j - i)

But current code effectively does:
    | sum(j - i) |

This mixes positive and negative values BEFORE applying absolute,
which leads to incorrect cancellation.

Counterexample:
    nums = [1, 1, 1]
    indices = [0, 1, 2]

For i = 1:
    Correct = |1-0| + |1-2| = 1 + 1 = 2

    Current formula:
        sum = 0 + 1 + 2 = 3
        count = 3
        |3 - 3*1| = 0  ❌ WRONG

Why it fails:
    (1 - 0) = +1
    (1 - 2) = -1

    |+1| + |-1| = 2
    but
    |(+1) + (-1)| = 0

Conclusion:
We cannot collapse absolute differences into a single expression.
We MUST split into:
    left contribution + right contribution

Fix:
Use prefix sums over grouped indices to compute:
    left = i * pos[i] - sum(left indices)
    right = sum(right indices) - (count_right * pos[i])
*/                                                                        

class Solution {
public:
    vector<long long> distance(vector<int>& nums) {
        int n = nums.size();
        vector<long long> ans(n);

        unordered_map<int, vector<int>> mp;

        for(int i = 0; i < n; i++)
            mp[nums[i]].push_back(i);

        for(auto &it : mp){
            auto &pos = it.second;

            long long sum = 0;
            for(int x : pos) sum += x;

            long long leftSum = 0;
            int m = pos.size();

            for(int i = 0; i < m; i++){
                long long rightSum = sum - leftSum - pos[i];

                long long left  = 1LL * pos[i] * i - leftSum;
                long long right = rightSum - 1LL * pos[i] * (m-i-1);

                ans[pos[i]] = left + right;

                leftSum += pos[i];
            }
        }

        return ans;
    }
};
